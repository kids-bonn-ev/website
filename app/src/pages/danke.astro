---
import BaseLayout from "../layouts/BaseLayout.astro";
import Button from "../components/Button.astro";
import Deko from "../components/Deko.astro";
---

<BaseLayout
  title="Danke! — KIDS e.V."
  description="Wir haben eure Nachricht bekommen und melden uns bald."
>
  <section class="danke-hero">
    <Deko name="wolke" size={140} top="12%" left="8%" rotate={-6} opacity={0.85} class="deko--hide-mobile" />
    <Deko name="blume01" size={90} top="18%" right="10%" rotate={12} class="deko--hide-mobile" />
    <Deko name="kreis" size={80} bottom="18%" right="18%" class="deko--hide-mobile" />
    <Deko name="regenwurm" size={160} bottom="-10px" left="50%" rotate={-8} class="danke-wurm" />

    <div class="container danke-inner">
      <p class="eyebrow">Angekommen</p>
      <h1>
        Danke — <span class="hero__hl hero__hl--orange">wir haben's</span>.
      </h1>
      <p class="lede">
        Eure Nachricht ist bei uns gelandet. Wir melden uns innerhalb weniger
        Tage persönlich. Bei dringenden Fragen ruft gerne direkt an:
        <a href="tel:+492284787950"><strong>0228&nbsp;478795</strong></a>
        (Mo–Fr 9:00–11:00&nbsp;Uhr).
      </p>

      <div class="danke-ctas">
        <Button href="/">Zur Startseite</Button>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .danke-hero {
    position: relative;
    overflow: hidden;
    background: var(--c-bg-cream);
    padding-block: clamp(4rem, 10vw, 7rem);
    min-height: 60vh;
    display: grid;
    place-items: center;
  }
  .danke-inner {
    position: relative;
    text-align: center;
    max-width: 42rem;
  }
  .danke-inner h1 {
    margin-block: var(--s-3) var(--s-5);
  }
  .danke-inner .lede {
    margin-inline: auto;
  }
  .danke-ctas {
    display: flex;
    justify-content: center;
    margin-top: var(--s-7);
  }
  :global(.danke-wurm) {
    transform: translateX(-50%) rotate(-8deg) !important;
  }
</style>
