---
interface Props {
  name:
    | "blume01"
    | "blume02"
    | "bogen"
    | "halbkreis"
    | "kreis"
    | "strich"
    | "tropfen"
    | "welle"
    | "wiese01"
    | "wiese02"
    | "wolke"
    | "regenwurm";
  size?: number | string;
  top?: string;
  left?: string;
  right?: string;
  bottom?: string;
  rotate?: number;
  opacity?: number;
  class?: string;
}

const {
  name,
  size = 80,
  top,
  left,
  right,
  bottom,
  rotate = 0,
  opacity = 1,
  class: className,
} = Astro.props;

const src = name === "regenwurm" ? "/logos/regenwurm.png" : `/deco/${name}.svg`;
const sizeValue = typeof size === "number" ? `${size}px` : size;

const style = [
  top && `top:${top}`,
  left && `left:${left}`,
  right && `right:${right}`,
  bottom && `bottom:${bottom}`,
  `width:${sizeValue}`,
  `transform:rotate(${rotate}deg)`,
  `opacity:${opacity}`,
]
  .filter(Boolean)
  .join(";");
---

<img
  src={src}
  alt=""
  class:list={["deko", className]}
  style={style}
  loading="lazy"
  aria-hidden="true"
/>
