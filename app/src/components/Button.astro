---
interface Props {
  href: string;
  variant?: "primary" | "outline" | "ghost" | "primary-inverse" | "outline-inverse";
  size?: "sm" | "md" | "lg";
  external?: boolean;
  class?: string;
}

const {
  href,
  variant = "primary",
  size = "md",
  external = false,
  class: className,
} = Astro.props;
const target = external ? "_blank" : undefined;
const rel = external ? "noopener" : undefined;
---

<a
  href={href}
  class:list={["btn", `btn--${variant}`, `btn--${size}`, className]}
  target={target}
  rel={rel}
  data-external={external ? "" : undefined}
>
  <slot />
</a>
