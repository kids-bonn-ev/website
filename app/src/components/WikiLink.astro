---
const WIKI_ROOT = "https://docs.kids-bonn.de/docs/f5f02dd9-0071-4b55-8301-8d6ee5411431/";

interface Props {
  href?: string;
  class?: string;
}

const { href = WIKI_ROOT, class: className } = Astro.props;
---

<a href={href} class:list={["wiki-link", className]} target="_blank" rel="noopener" data-external>
  <slot />
</a>

<style>
  .wiki-link {
    display: inline-flex;
    align-items: center;
    gap: var(--s-2);
    font-weight: 800;
    color: var(--c-link);
    text-decoration: none;
    border-bottom: 2px dashed color-mix(in srgb, var(--c-orange) 50%, transparent);
    padding-bottom: 2px;
  }
  .wiki-link:hover {
    color: var(--c-link-hover);
    border-bottom-color: var(--c-orange);
  }
</style>
