---
import BaseLayout from "../layouts/BaseLayout.astro";
import Deko from "../components/Deko.astro";

const spendenArten = [
  "Einmalige Spende",
  "Regelmäßige Spende",
  "Anlass-Spende (Geburtstag, Jubiläum, …)",
  "Zweckgebunden (Garten, Ausstattung, Projekte)",
];
---

<BaseLayout
  title="Spenden – KIDS e.V."
  description="Eure Spende unterstützt uns beim Ausstatten der Räume, beim Garten und bei besonderen Projekten. Bankverbindung und Formular für die Spendenquittung."
>

  <section class="spenden-hero">
    <Deko name="kreis" size={120} top="20%" right="8%" class="deko--hide-mobile" />
    <Deko name="blume01" size={90} bottom="12%" left="10%" rotate={-10} class="deko--hide-mobile" />

    <div class="container spenden-hero__inner">
      <p class="eyebrow">Unterstützen</p>
      <h1>Spenden.</h1>
      <p class="lede">
        Unsere Kita ist ein Ort der Freude, des Lernens und des Zusammenwachsens.
        Damit das so bleibt, brauchen wir Ihre Unterstützung.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container spenden-intro">
      <div class="prose">
        <p>
          Bei uns wachsen Kinder in einem liebevollen und geborgenen Umfeld auf -
          und legen hier die Grundlagen für eine positive Zukunft. Um all das
          möglich zu machen, sind wir auf Ihre Hilfe angewiesen.
        </p>
        <p>
          Mit Ihrer Spende verbessern wir unsere Räume, kaufen neue Spielmaterialien,
          ermöglichen Bildungsangebote und besondere Veranstaltungen. Jeder Euro
          zählt und bringt uns einen Schritt näher, noch mehr Möglichkeiten für
          unsere Kinder zu schaffen.
        </p>
        <p>
          <strong>Helfen Sie uns, unsere Vision zu verwirklichen.</strong>
          Jeder Beitrag - egal wie klein - macht einen Unterschied.
          Vielen Dank für Ihre Unterstützung!
        </p>
      </div>
    </div>
  </section>

  <section class="section section--cream">
    <div class="container">
      <div class="bank-card">
        <p class="eyebrow">Bankverbindung</p>
        <h2>So erreicht uns Ihre Spende.</h2>
        <dl class="bank-details">
          <div>
            <dt>Empfänger</dt>
            <dd>KIDS e.V.</dd>
          </div>
          <div>
            <dt>IBAN</dt>
            <dd><code>DE93 3806 0186 0201 7170 19</code></dd>
          </div>
          <div>
            <dt>BIC</dt>
            <dd><code>GENODED1BRS</code></dd>
          </div>
        </dl>
        <p class="bank-note">
          Für Ihre Spende stellen wir gerne eine <strong>Spendenquittung</strong> aus.
          Füllen Sie dafür das Formular unten aus - wir kümmern uns um den Rest.
        </p>
      </div>
    </div>
  </section>

  <section class="section" id="quittung">
    <div class="container">
      <div class="section__head">
        <p class="eyebrow">Spendenquittung</p>
        <h2>Ihre Angaben.</h2>
        <p class="lede">
          Pflichtfelder sind mit <span aria-hidden="true">*</span> markiert.
        </p>
      </div>

      <form class="spenden-form" method="post" action="/api/submit">
        <input type="hidden" name="_form" value="spenden" />
        {/* Honeypot — hidden from real users, bots fill it. */}
        <div class="honeypot" aria-hidden="true">
          <label>Website <input type="text" name="website" tabindex="-1" autocomplete="off" /></label>
        </div>

        <fieldset class="field field--group">
          <legend>Anrede</legend>
          <div class="radio-row">
            <label><input type="radio" name="Anrede" value="Herr" /> <span>Herr</span></label>
            <label><input type="radio" name="Anrede" value="Frau" /> <span>Frau</span></label>
            <label><input type="radio" name="Anrede" value="Divers" /> <span>Divers</span></label>
          </div>
        </fieldset>

        <div class="field-row">
          <div class="field">
            <label for="s-vorname">Vorname <span aria-hidden="true">*</span></label>
            <input id="s-vorname" name="Vorname" type="text" required autocomplete="given-name" />
          </div>
          <div class="field">
            <label for="s-nachname">Nachname <span aria-hidden="true">*</span></label>
            <input id="s-nachname" name="Nachname" type="text" required autocomplete="family-name" />
          </div>
        </div>

        <div class="field">
          <label for="s-strasse">Straße und Hausnummer</label>
          <input id="s-strasse" name="Strasse" type="text" autocomplete="street-address" />
        </div>

        <div class="field-row field-row--plz">
          <div class="field">
            <label for="s-plz">Postleitzahl</label>
            <input id="s-plz" name="PLZ" type="text" inputmode="numeric" autocomplete="postal-code" />
          </div>
          <div class="field">
            <label for="s-ort">Ort</label>
            <input id="s-ort" name="Ort" type="text" autocomplete="address-level2" />
          </div>
        </div>

        <div class="field">
          <label for="s-email">E-Mail-Adresse <span aria-hidden="true">*</span></label>
          <input id="s-email" name="E-Mail" type="email" required autocomplete="email" />
        </div>

        <div class="field-row">
          <div class="field">
            <label for="s-iban">IBAN <span aria-hidden="true">*</span></label>
            <input id="s-iban" name="IBAN" type="text" required placeholder="DE…" />
          </div>
          <div class="field">
            <label for="s-bic">BIC <span aria-hidden="true">*</span></label>
            <input id="s-bic" name="BIC" type="text" required />
          </div>
        </div>

        <div class="field-row">
          <div class="field">
            <label for="s-betrag">Betrag (€) <span aria-hidden="true">*</span></label>
            <input id="s-betrag" name="Betrag" type="number" step="0.01" min="1" required />
          </div>
          <div class="field">
            <label for="s-art">Art der Spende <span aria-hidden="true">*</span></label>
            <select id="s-art" name="Spendenart" required>
              <option value="" disabled selected>– Bitte auswählen –</option>
              {spendenArten.map((a) => <option value={a}>{a}</option>)}
            </select>
          </div>
        </div>

        <div class="field">
          <label for="s-kommentar">Kommentar</label>
          <textarea
            id="s-kommentar"
            name="Kommentar"
            rows="4"
            placeholder="Anlass, Widmung oder Nachricht an uns - optional."
          ></textarea>
        </div>

        <p class="form-datenschutz-note">
          Ihre Angaben verarbeiten wir ausschließlich zur Bearbeitung Ihrer
          Spende. Details dazu in unserer <a href="/datenschutz">Datenschutzerklärung</a>.
        </p>

        <div class="spenden-form__actions">
          <button type="submit" class="btn btn--primary">Anfrage absenden</button>
        </div>
      </form>
    </div>
  </section>

</BaseLayout>

<style>
  .spenden-hero {
    position: relative;
    overflow: hidden;
    background: var(--c-bg-cream);
    padding-block: clamp(3rem, 7vw, 5rem);
    text-align: center;
  }
  .spenden-hero__inner {
    position: relative;
  }
  .spenden-hero h1 { margin-block: var(--s-3) var(--s-5); }
  .spenden-hero .lede { max-width: 44rem; margin-inline: auto; }

  .spenden-intro {
    max-width: 48rem;
    margin-inline: auto;
  }
  .spenden-intro p {
    max-width: none;
  }

  /* Bank card */
  .bank-card {
    background: #fff;
    border-radius: var(--r-lg);
    padding: clamp(1.5rem, 4vw, 2.5rem);
    box-shadow: var(--shadow-md);
    max-width: 52rem;
    margin-inline: auto;
  }
  .bank-card h2 { margin-bottom: var(--s-5); }
  .bank-details {
    display: flex;
    flex-wrap: wrap;
    gap: var(--s-4) var(--s-7);
    margin: 0 0 var(--s-5);
  }
  .bank-details > div {
    flex: 0 0 auto;
  }
  .bank-details dt {
    font-weight: 800;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--c-ink-soft);
    margin-bottom: var(--s-1);
  }
  .bank-details dd {
    margin: 0;
    font-size: 1.1rem;
    white-space: nowrap;
  }
  .bank-details code {
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 1rem;
    white-space: nowrap;
  }
  .bank-note {
    margin: 0;
    padding-top: var(--s-4);
    border-top: 1px solid var(--c-bg-sand);
    color: var(--c-ink-soft);
  }

  /* Form */
  /* Honeypot — hidden from sighted users and assistive tech, bots find it. */
  .honeypot {
    position: absolute;
    left: -10000px;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }

  .spenden-form {
    background: #fff;
    border-radius: var(--r-lg);
    padding: clamp(1.5rem, 4vw, 2.5rem);
    box-shadow: var(--shadow-md);
    max-width: 48rem;
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    gap: var(--s-4);
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: var(--s-2);
  }
  .field label,
  .field legend {
    font-weight: 700;
    color: var(--c-ink);
    font-size: 0.95rem;
  }
  .field input[type="text"],
  .field input[type="email"],
  .field input[type="number"],
  .field input[type="tel"],
  .field select,
  .field textarea {
    font: inherit;
    padding: 0.7rem 0.9rem;
    border: 2px solid var(--c-bg-sand);
    border-radius: var(--r-md);
    background: var(--c-bg);
    color: var(--c-ink);
    transition: border-color 140ms ease;
  }
  .field textarea {
    resize: vertical;
    min-height: 5.5rem;
    line-height: 1.5;
  }
  .field input:focus,
  .field select:focus,
  .field textarea:focus {
    outline: none;
    border-color: var(--c-orange);
  }

  .field--group {
    border: none;
    padding: 0;
    margin: 0;
  }
  .field--group legend {
    margin-bottom: var(--s-2);
  }
  .radio-row {
    display: flex;
    gap: var(--s-4);
    flex-wrap: wrap;
  }
  .radio-row label {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 600;
    color: var(--c-ink);
    cursor: pointer;
  }
  .radio-row input[type="radio"] {
    width: 1.1rem;
    height: 1.1rem;
    accent-color: var(--c-orange);
    margin: 0;
  }

  .field-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--s-4);
  }
  .field-row--plz {
    grid-template-columns: 1fr 2fr;
  }
  @media (max-width: 600px) {
    .field-row,
    .field-row--plz {
      grid-template-columns: 1fr;
    }
  }

  .field--check {
    flex-direction: row;
    align-items: flex-start;
    gap: var(--s-3);
    font-weight: 400;
    font-size: 0.95rem;
    color: var(--c-ink-soft);
    line-height: 1.5;
  }
  .field--check input[type="checkbox"] {
    width: 1.1rem;
    height: 1.1rem;
    margin-top: 0.25rem;
    accent-color: var(--c-orange);
  }

  .spenden-form__actions {
    margin-top: var(--s-3);
  }

</style>
