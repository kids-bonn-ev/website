<script>
  // Scroll-snap Galerie: Pagination-Dots + Pfeil-Buttons
  type GalleryContext = {
    root: HTMLElement;
    track: HTMLElement;
    slides: HTMLElement[];
    dots: HTMLButtonElement[];
    prev: HTMLButtonElement | null;
    next: HTMLButtonElement | null;
    activeIndex: number;
  };

  const setupGallery = (root: HTMLElement) => {
    const track = root.querySelector<HTMLElement>("[data-gallery-track]");
    if (!track) return;

    const slides = Array.from(root.querySelectorAll<HTMLElement>("[data-gallery-slide]"));
    const dots = Array.from(root.querySelectorAll<HTMLButtonElement>("[data-gallery-dot]"));
    const prev = root.querySelector<HTMLButtonElement>("[data-gallery-prev]");
    const next = root.querySelector<HTMLButtonElement>("[data-gallery-next]");

    const ctx: GalleryContext = {
      root,
      track,
      slides,
      dots,
      prev,
      next,
      activeIndex: 0,
    };

    const updateActive = (i: number) => {
      ctx.activeIndex = i;
      ctx.dots.forEach((d, idx) => {
        if (idx === i) d.setAttribute("aria-current", "true");
        else d.removeAttribute("aria-current");
      });
      if (ctx.prev) ctx.prev.disabled = i === 0;
      if (ctx.next) ctx.next.disabled = i === ctx.slides.length - 1;
    };

    // Track which slide is centered via IntersectionObserver
    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting && entry.intersectionRatio > 0.6) {
            const idx = Number(
              (entry.target as HTMLElement).getAttribute("data-gallery-slide")
            );
            updateActive(idx);
          }
        }
      },
      { root: track, threshold: [0.6, 0.9] }
    );
    ctx.slides.forEach((s) => observer.observe(s));

    // Click dots to navigate
    ctx.dots.forEach((dot, i) => {
      dot.addEventListener("click", () => {
        ctx.slides[i]?.scrollIntoView({
          behavior: "smooth",
          block: "nearest",
          inline: "center",
        });
      });
    });

    // Arrow buttons
    const go = (delta: number) => {
      const target = Math.min(Math.max(ctx.activeIndex + delta, 0), ctx.slides.length - 1);
      ctx.slides[target]?.scrollIntoView({
        behavior: "smooth",
        block: "nearest",
        inline: "center",
      });
    };
    ctx.prev?.addEventListener("click", () => go(-1));
    ctx.next?.addEventListener("click", () => go(1));

    updateActive(0);
  };

  document.querySelectorAll<HTMLElement>("[data-gallery]").forEach(setupGallery);
</script>
