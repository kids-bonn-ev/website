---
import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import Button from "../components/Button.astro";
import Deko from "../components/Deko.astro";
import WikiLink from "../components/WikiLink.astro";
import hausImage1 from "../assets/haus-1.jpeg";
import hausImage2 from "../assets/haus-2.jpeg";
import hausImage3 from "../assets/haus-3.jpeg";

const hausGallery = [
  { src: hausImage1, alt: "Außenansicht unseres Neubaus in Bonn-Beuel" },
  { src: hausImage2, alt: "Blick in den Garten mit Spielbereich" },
  { src: hausImage3, alt: "Innenansicht mit Gruppenraum und Spielmaterialien" },
];

const sponsorMeta: Record<string, { name: string; href: string }> = {
  "anne-servos": { name: "Anne Servos", href: "https://anne-servos.de/" },
  "beueler-buchladen": { name: "Beueler Buchladen", href: "https://beuelerbuchladen.de/" },
  "bindungsaspekte": { name: "Bindungsaspekte", href: "https://bindungsaspekte.de/" },
  "buggyfit": { name: "buggyFit", href: "https://www.buggyfit.de/" },
  "koerperzimmer": { name: "Körperzimmer", href: "https://koerperzimmer.de/" },
  "limas": { name: "LiMa's Fairpackte Welt", href: "https://limasfairpacktewelt.de/" },
  "miss-minz": { name: "Miss Minz", href: "https://www.instagram.com/miss.minz/" },
  "musikschule-metronom": { name: "Musikschule Metronom", href: "https://musikschule-beuel.de/" },
  "zartmint": { name: "zartmint", href: "https://www.zartmint.de/" },
};

const sponsorLogos = Object.entries(
  import.meta.glob<{ default: ImageMetadata }>(
    "../assets/sponsoren/*.{jpg,jpeg,png,svg}",
    { eager: true }
  )
).map(([path, mod]) => {
  const slug = path.split("/").pop()?.replace(/\.[^.]+$/, "") ?? "";
  const meta = sponsorMeta[slug] ?? { name: slug, href: "#" };
  return { src: mod.default, alt: `Logo ${meta.name}`, href: meta.href };
});
---

<BaseLayout
  title="KIDS e.V. – Ein Ort zum Wachsen, Staunen und Freunde finden"
  description="Elternhand statt Fremdträger: drei feste Gruppen, 50 Kinder, ein großer Garten. Raum zum Wachsen, Staunen und Freunde finden."
>

  <section class="hero">
    <Deko name="wolke"    size={170} top="10%"  left="6%"   rotate={-6} opacity={0.85} class="deko--hide-mobile" />
    <Deko name="blume01"  size={110} top="16%"  right="12%" rotate={12} class="deko--hide-mobile" />
    <Deko name="kreis"    size={95}  top="56%"  right="6%"  class="deko--hide-mobile" />
    <Deko name="wiese01"  size={260} bottom="-20px" left="-40px" class="deko--hero-ground" />
    <Deko name="halbkreis" size={140} bottom="6%" right="10%" rotate={-20} opacity={0.9} class="deko--hide-mobile" />

    <div class="container hero__inner">
      <a href="/kennenlernen" class="announce">
        <img src="/deco/blume02.svg" alt="" class="announce__icon" aria-hidden="true" />
        <span class="announce__text">Jetzt zum Kennenlernen eintragen</span>
      </a>

      <h1>
        Ein Ort zum <span class="hero__hl hero__hl--gruen">Wachsen</span>,<br />
        <span class="hero__hl hero__hl--orange">Staunen</span> &amp;
        <span class="hero__hl hero__hl--blau">Freunde</span>&nbsp;finden.
      </h1>

      <p class="lede">
        Wir sind KIDS&nbsp;e.V. - Eine Elterninitiative mit
        <strong>50&nbsp;Kindern</strong>,
        <strong>13&nbsp;Erzieher:innen</strong> und einem großen Garten mitten in Beuel.
        Hier darf jedes Kind sein.
      </p>

      <div class="hero__ctas">
        <Button href="/kennenlernen">Kennenlernen</Button>
        <Button
          href="https://docs.kids-bonn.de/docs/f5f02dd9-0071-4b55-8301-8d6ee5411431/"
          variant="outline"
          external
        >
          Wie funktioniert der KIDS
        </Button>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container besonders">
      <div class="besonders__head">
        <p class="eyebrow">Klein, selbstgemacht, voller Spiel.</p>
        <h2>Was uns besonders macht.</h2>
        <p class="besonders__lead">
          Bei uns bestimmen die Kinder den Rhythmus. Wir folgen ihrer Neugier,
          nehmen ihre Fragen ernst und geben ihnen die Zeit, die Großwerden braucht.
        </p>
      </div>

      <div class="besonders__grid">
        <article class="b-card">
          <Deko name="kreis" size={52} class="b-card__icon" />
          <h3>Drei feste Gruppen</h3>
          <p>
            <strong>Mond</strong>, <strong>Sonne</strong> und <strong>Zwerge</strong>.
            Gemischtes Alter von 1&nbsp;bis&nbsp;6&nbsp;Jahren. Keine ständigen Wechsel.
          </p>
        </article>

        <article class="b-card">
          <Deko name="blume01" size={52} class="b-card__icon" />
          <h3>Frisch gekocht</h3>
          <p>
            Unser Küchenteam zaubert (beinahe) täglich eine warme Mahlzeit —
            bio, saisonal, kindgerecht.
          </p>
        </article>

        <article class="b-card">
          <Deko name="welle" size={56} class="b-card__icon" />
          <h3>Eltern mittendrin</h3>
          <p>
            Als Elterninitiative gestalten Familien den Alltag aktiv mit -
            soviel wie passt.
          </p>
        </article>

        <article class="b-card">
          <Deko name="wiese02" size={56} class="b-card__icon" />
          <h3>Neubau &amp; Garten mit 1700&nbsp;m²</h3>
          <p>
            Hochbeete, Sandkiste, Matschecke und ein alter Birnbaum -
            unser liebster Klassenraum.
          </p>
        </article>
      </div>
    </div>
  </section>

  <section class="section section--cream" id="leitbild">
    <Deko name="strich" size={140} top="8%" right="-30px" rotate={25} opacity={0.6} />
    <div class="container grid-2 konzept">
      <div>
        <p class="eyebrow">Unser Leitbild</p>
        <h2>Bewusst handeln.<br />Gemeinsam wachsen.</h2>
      </div>
      <div class="prose">
        <p>
          Wir schaffen einen Ort, an dem Kinder sich sicher fühlen, Fragen stellen
          und wachsen dürfen. Unsere Haltung in sechs Sätzen:
        </p>
        <ul class="leitbild-list">
          <li><strong>Jedes Kind zählt.</strong> Mit allem, was es mitbringt.</li>
          <li><strong>Zusammen.</strong> Kinder, Eltern, Team auf Augenhöhe.</li>
          <li><strong>Eltern packen an.</strong> Von Konzept bis Laternenfest.</li>
          <li><strong>Alltag ist Lernen.</strong> Was Kinder selbst tun, bleibt.</li>
          <li><strong>Wir sehen jedes Kind.</strong> Aufmerksam, ehrlich, verlässlich.</li>
          <li><strong>Heute für morgen.</strong> Nachhaltigkeit ist Haltung, keine Deko.</li>
        </ul>
        <WikiLink href="https://docs.kids-bonn.de/docs/ab36eedf-a7d8-4185-8066-c8ce44e42fb2/">Unser Leitbild im Wortlaut</WikiLink>
      </div>
    </div>
  </section>

  <section class="section" id="alltag">
    <div class="container">
      <div class="tag-head">
        <div class="tag-head__left">
          <p class="eyebrow">Ein Tag im KIDS</p>
          <h2>Genug Zeit.<br />Für alles, was zählt.</h2>
        </div>
        <div class="tag-head__right">
          <p class="tag-head__lead">
            Unser Tag hat einen festen Rhythmus - und viel Luft dazwischen.
            Denn Kinder brauchen beides: Struktur und das Gefühl, nicht gehetzt
            zu werden.
          </p>
          <p class="tag-head__link">
            <WikiLink href="https://docs.kids-bonn.de/docs/8ab81424-039b-42b8-95b4-6e2525c6c4f7/">
              Mehr zu Tagesablauf, Essen, Ausflügen, Ferien
            </WikiLink>
          </p>
        </div>
      </div>

      <div class="day-grid">
        <article class="day-block" style="--tile: var(--c-pfirsich);">
          <span class="day-block__time">Ab 7:30</span>
          <div>
            <h3>Ankommen</h3>
            <p>Tür auf, Schuhe aus, erste Freunde begrüßen.</p>
          </div>
        </article>

        <article class="day-block" style="--tile: var(--c-gelb);">
          <span class="day-block__time">09:00</span>
          <div>
            <h3>Morgenkreis</h3>
            <p>Lieder, Wetter, was heute wichtig ist.</p>
          </div>
        </article>

        <article class="day-block" style="--tile: var(--c-gruen);">
          <span class="day-block__time">Ab 9:30</span>
          <div>
            <h3>Freies Spielen</h3>
            <p>Drinnen, draußen, matschig, laut.</p>
          </div>
        </article>

        <article class="day-block day-block--dark" style="--tile: var(--c-orange);">
          <span class="day-block__time">12:00</span>
          <div>
            <h3>Mittagessen</h3>
            <p>Frisch vor Ort gekocht, gemeinsam gegessen.</p>
          </div>
        </article>

        <article class="day-block" style="--tile: var(--c-lila);">
          <span class="day-block__time">Ab 13:00</span>
          <div>
            <h3>Ruhe &amp; Projekte</h3>
            <p>Erst Schlaf oder Geschichten, dann Atelier und Bewegung.</p>
          </div>
        </article>

        <article class="day-block" style="--tile: var(--c-blau);">
          <span class="day-block__time">15:00</span>
          <div>
            <h3>Abholzeit</h3>
            <p>Taschen schnappen, winken, bis morgen.</p>
          </div>
        </article>
      </div>

    </div>
  </section>

  <section class="section section--sand">
    <div class="container">
      <div class="ei-head">
        <div class="ei-head__left">
          <p class="eyebrow">Elterninitiative</p>
          <h2>Unsere Kita.<br/>Im wahrsten Sinn.</h2>
        </div>
        <div class="ei-head__right">
          <p class="ei-head__lead">
            Als Elterninitiative gestalten wir unsere Kita selbst.
            Jede Familie bringt sich ein: in Arbeitsgruppen, in
            administrativen Gremien, bei Festen und im täglichen Miteinander.
          </p>
          <p class="ei-head__link">
            <WikiLink href="https://docs.kids-bonn.de/docs/68fc95e6-91aa-4c8e-bf67-e60393ef0540/">
              Elterngruppen im Detail
            </WikiLink>
          </p>
        </div>
      </div>

      <div class="ei-groups">
        <article class="ei-block">
          <h3>Gremien</h3>
          <p class="ei-block__sub">
            Gewählt auf der Mitgliederversammlung. Sie tragen Verantwortung
            für Mitarbeitende, Verein und Haus.
          </p>
          <ul class="ei-chips">
            <li>Vorstand</li>
            <li>Elternrat</li>
          </ul>
        </article>

        <article class="ei-block">
          <h3>Arbeitsgruppen</h3>
          <p class="ei-block__sub">
            Fluide und bedarfsorientiert. Jedes Jahr stimmen wir neu ab,
            was gerade ansteht und packen es an.
          </p>
          <ul class="ei-chips">
            <li>Feste</li>
            <li>Hausmeisterschaft &amp; Garten</li>
            <li>IT</li>
            <li>Mitgliedermanagement</li>
            <li>Einkauf</li>
            <li>Nachhaltigkeit &amp; Fundraising</li>
            <li>Kids-PR</li>
            <li>Kids-Post</li>
            <li>Schutzkonzept</li>
          </ul>
        </article>
      </div>

      <div class="ei-call">
        <p class="ei-call__line ei-call__line--q">
          <span class="hand">Du willst mehr als nur bringen und abholen?</span>
        </p>
        <p class="ei-call__line ei-call__line--a">
          <span class="hand">Dann seid ihr bei uns richtig.</span>
        </p>
      </div>

      <div class="ei-verein">
        <p>
          KIDS&nbsp;e.V. gehört keinem Träger, keiner Kirche und keiner Firma.
          Er gehört uns allen. Jede Familie ist Mitglied im Verein, bringt
          <strong>3&nbsp;bis&nbsp;5&nbsp;Stunden Mitarbeit pro Monat</strong>
          ein und entscheidet bei den großen Fragen mit.
        </p>
        <p>
          Das klingt nach viel. Ist es auch. Aber Eltern sagen uns immer wieder:
          Genau das ist der Grund, warum sich KIDS nicht wie eine Kita
          anfühlt, sondern wie <em>unsere</em> Kita.
        </p>
      </div>
    </div>
  </section>

  <section class="section section--cream" id="haus">
    <div class="container haus">
      <div class="haus-gallery" data-gallery>
        <div class="haus-gallery__track" data-gallery-track>
          {hausGallery.map((photo, i) => (
            <figure class="haus-gallery__slide" data-gallery-slide={i}>
              <Image
                src={photo.src}
                alt={photo.alt}
                widths={[480, 768, 1024, 1400]}
                sizes="(max-width: 800px) 92vw, 44vw"
                formats={["webp"]}
                loading={i === 0 ? "eager" : "lazy"}
                decoding="async"
              />
            </figure>
          ))}
        </div>

        <button
          type="button"
          class="haus-gallery__arrow haus-gallery__arrow--prev"
          aria-label="Vorheriges Foto"
          data-gallery-prev
        >
          ←
        </button>
        <button
          type="button"
          class="haus-gallery__arrow haus-gallery__arrow--next"
          aria-label="Nächstes Foto"
          data-gallery-next
        >
          →
        </button>

        <div class="haus-gallery__dots" role="tablist" aria-label="Foto auswählen">
          {hausGallery.map((_, i) => (
            <button
              type="button"
              class="haus-gallery__dot"
              role="tab"
              aria-label={`Foto ${i + 1} von ${hausGallery.length}`}
              data-gallery-dot={i}
            ></button>
          ))}
        </div>
      </div>

      <div class="haus-body">
        <h2>Unser Haus.</h2>
        <p>
          Seit unserem Umzug sind wir in einem <strong>Neubau mitten in Bonn-Beuel</strong> -
          hell, warm und richtig groß. Drumherum: <strong>1.700&nbsp;m² Garten</strong>
          zum Toben, Wühlen und Entdecken.
        </p>
        <p>
          Jeder Raum hat seine Aufgabe: die Turnhalle mit Kletterwand fürs laute Tun,
          die Werkstatt zum Bauen, das Atelier zum Matschen. Alles so eingerichtet,
          dass die Kinder selbstständig handeln können.
        </p>

        <ul class="haus-features">
          <li>1.700&nbsp;m² Garten</li>
          <li>3 Gruppenräume</li>
          <li>Turnhalle mit Kletterwand</li>
          <li>Eigene Küche</li>
          <li>Werkstatt</li>
          <li>Atelier</li>
          <li>Ruheräume</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="section" id="mitmachen">
    <div class="container">
      <div class="kommvorbei">
        <Deko name="kreis"  size={260} top="-60px" right="-60px" opacity={0.55} />
        <Deko name="welle"  size={180} bottom="-30px" right="14%" rotate={-20} opacity={0.35} />
        <Deko name="blume02" size={120} bottom="-10px" left="6%" rotate={15} opacity={0.5} />

        <div class="kommvorbei__inner">
          <p class="eyebrow kommvorbei__eyebrow">Noch Plätze frei</p>
          <h2>
            Komm vorbei. Schau dich um.<br />
            Fühl, ob wir passen.
          </h2>
          <p class="kommvorbei__text">
            Lernt uns kennen - beim Tag der offenen Tür oder in einem persönlichen
            Gespräch. Kein Bewerbungsritual, nur Kaffee, Kekse und ehrliche Fragen.
          </p>
          <div class="kommvorbei__ctas">
            <Button href="/kennenlernen" variant="primary-inverse">Zum Kennenlernen →</Button>
            <Button href="/kontakt" variant="outline-inverse">Fragen stellen</Button>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--sand-deep jobs-section" id="jobs">
    <Deko name="blume02" size={560} top="-120px" right="-140px" rotate={18} opacity={0.15} class="deko--hide-mobile" />

    <div class="container jobs-teaser">
      <div>
        <p class="eyebrow">Jobs @ KIDS</p>
        <h2>Erzieher:in mit Haltung? Komm ins Team.</h2>
        <p class="lede">
          Kleine Gruppen. Rückendeckung durch Eltern im Alltag. Raum, wirklich
          pädagogisch zu arbeiten - statt Verwaltung zu machen. Und: wir suchen
          gerade Verstärkung.
        </p>
        <Button href="/jobs">Offene Stellen ansehen</Button>
      </div>

      <aside class="jobs-teaser__points">
        <h3 class="visually-hidden">Vorteile</h3>
        <ul>
          <li>Kleines Team, viel Rückendeckung</li>
          <li>Mitgestalten, nicht abarbeiten</li>
          <li>Kurze Wege, schnelle Entscheidungen</li>
          <li>Zeit für echte pädagogische Arbeit</li>
        </ul>
      </aside>
    </div>
  </section>

  <section class="section sponsoren-section" id="sponsoren">
    <div class="container">
      <div class="section__head sponsoren__head">
        <p class="eyebrow">Danke!</p>
        <h2>Unsere Sponsoren.</h2>
        <p class="sponsoren__lead">
          Ohne die Unterstützung lokaler Betriebe und Initiativen wäre vieles
          bei uns nicht möglich. Schaut gerne bei ihnen vorbei.
        </p>
      </div>

      <ul class="sponsoren-grid">
        {sponsorLogos.map((logo) => (
          <li class="sponsoren-grid__item">
            <a
              href={logo.href}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={logo.alt}
            >
              <Image
                src={logo.src}
                alt={logo.alt}
                widths={[160, 240, 320]}
                sizes="(max-width: 600px) 40vw, 180px"
                formats={["webp"]}
                loading="lazy"
                decoding="async"
              />
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="section section--cream" id="kontakt">
    <div class="container">
      <div class="section__head">
        <p class="eyebrow">Kontakt</p>
        <h2>Fragt uns.<br />Wir antworten.</h2>
      </div>

      <div class="kontakt-box">
        <h3>Direkt erreichbar</h3>
        <p>
          Telefon: <a href="tel:+492284787950"><strong>0228 478795</strong></a><br />
          Mail: <a href="mailto:kita@kids-bonn.de"><strong>kita@kids-bonn.de</strong></a>
        </p>
        <Button href="/kontakt" variant="outline">Anfahrt &amp; alle Kontakte</Button>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .hero {
    position: relative;
    padding-block: clamp(3.5rem, 10vw, 8rem) clamp(5rem, 12vw, 10rem);
    overflow: hidden;
    background: var(--c-bg-cream);
  }

  .hero__inner {
    position: relative;
    text-align: center;
  }

  /* On mobile the bottom grass sits inside the viewport - scale it down
     so it frames the hero without swallowing the CTAs. */
  :global(.deko--hero-ground) {
    width: 260px;
  }
  @media (max-width: 700px) {
    :global(.deko--hero-ground) {
      width: 150px !important;
      left: -30px !important;
      bottom: -10px !important;
    }
  }

  /* Anmelde-Pille / Störer */
  .announce {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.3rem 0.85rem 0.3rem 0.5rem;
    background: #fff;
    color: var(--c-ink);
    border-radius: var(--r-pill);
    font-family: var(--font-body);
    font-weight: 800;
    font-size: 0.8rem;
    text-decoration: none;
    box-shadow: var(--shadow-md);
    transition: transform 180ms ease, box-shadow 180ms ease;
    margin-bottom: var(--s-6);
  }
  .announce:hover {
    transform: translateY(-2px) rotate(-0.5deg);
    box-shadow: var(--shadow-lg);
    color: var(--c-ink);
  }
  .announce__icon {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
  }
  .announce__text {
    white-space: nowrap;
  }
  @media (max-width: 520px) {
    .announce { font-size: 0.85rem; padding: 0.4rem 0.8rem 0.4rem 0.45rem; }
    .announce__text { white-space: normal; }
  }

  .hero__hl {
    display: inline-block;
    font-family: var(--font-display-black);
    position: relative;
  }
  .hero__hl::after {
    content: "";
    position: absolute;
    inset: auto -0.15em -0.05em -0.15em;
    height: 0.35em;
    z-index: -1;
    border-radius: var(--r-pill);
  }
  .hero__hl--gruen  { color: var(--c-gruen); }
  .hero__hl--gruen::after  { background: var(--c-gelb); }

  .hero__hl--orange { color: var(--c-orange); }
  .hero__hl--orange::after { background: var(--c-lila); }

  .hero__hl--blau   { color: var(--c-blau); }
  .hero__hl--blau::after   { background: var(--c-pfirsich); }

  .hero h1 {
    margin-block: 0 var(--s-5);
    text-wrap: balance;
  }

  .hero .lede {
    max-width: 42rem;
    margin-inline: auto;
    text-wrap: pretty;
  }
  @media (max-width: 520px) {
    .hero h1 { font-size: clamp(2rem, 8vw, 2.6rem); }
    .hero .lede { font-size: 1.1rem; }
  }

  .hero__ctas {
    display: flex;
    justify-content: center;
    gap: var(--s-4);
    margin-top: var(--s-6);
    flex-wrap: wrap;
  }
  /* Outline button gets the section's background so deco behind it doesn't bleed through on mobile. */
  .hero__ctas :global(.btn--outline) {
    background: var(--c-bg-cream);
  }
  @media (max-width: 520px) {
    .hero__ctas { flex-direction: column; align-items: stretch; gap: var(--s-3); }
    .hero__ctas :global(.btn) { justify-content: center; }
  }

  .card--feature {
    text-align: center;
    padding-top: var(--s-5);
  }
  .card__icon {
    position: static;
    margin: 0 auto var(--s-4);
  }
  .card--feature h3 {
    margin-bottom: var(--s-3);
  }

  /* "Was uns besonders macht" - 2-column layout with 4 cards */
  .besonders {
    display: grid;
    grid-template-columns: 0.9fr 1.3fr;
    gap: var(--s-8);
    align-items: start;
